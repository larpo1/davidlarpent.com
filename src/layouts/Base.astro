---
import '../styles/global.css';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ThemesNav from '../components/ThemesNav.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string[];
  type?: 'website' | 'article';
  articleMeta?: {
    publishedTime: string;
    author: string;
    tags: string[];
  };
  hideThemesNav?: boolean;
  activeThemeSlug?: string;
}

const {
  title,
  description = "Notes on philosophy, AI, cognitive science, and more.",
  image = "/og-default.jpg",
  keywords = [],
  type = "website",
  articleMeta,
  hideThemesNav = false,
  activeThemeSlug,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Author -->
    <meta name="author" content="David Larpent" />
    <link rel="author" href="https://davidlarpent.com/about" />

    <!-- Keywords (if provided) -->
    {keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(', ')} />
    )}

    <!-- Open Graph / Social -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title.replace(/ \| David Larpent$/, '')} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <!-- og:site_name removed to keep social cards clean -->

    <!-- Article-specific OG tags -->
    {articleMeta && (
      <>
        <meta property="article:published_time" content={articleMeta.publishedTime} />
        <meta property="article:author" content={articleMeta.author} />
        {articleMeta.tags.map(tag => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title.replace(/ \| David Larpent$/, '')} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="David Larpent" href="/rss.xml" />

    <!-- Preload self-hosted Newsreader fonts (served from /fonts/) -->
    <link rel="preload" href="/fonts/newsreader-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/newsreader-italic.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Theme: Dark mode by default -->
    <script is:inline>
      // Set dark mode by default, allow override via localStorage
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    </script>

    <!-- Analytics are loaded after first paint (see body script) -->
    <!-- Additional head content (JSON-LD, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <div class="site-branding">
          <button id="theme-toggle" aria-label="Toggle theme">
            <img src="/sitelogo.png" alt="" class="theme-logo" />
          </button>
          <h1 class="site-title">
            <a href="/">Field Notes</a>
          </h1>
        </div>
        <nav class="site-nav">
        </nav>
      </header>
      {!hideThemesNav && <ThemesNav activeSlug={activeThemeSlug} />}
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <nav class="footer-nav">
          <a href="/about">About</a>
          <a href="/rss.xml">RSS</a>
        </nav>
        <NewsletterSignup variant="inline" />
      </footer>
    </div>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      toggle?.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>

    {!import.meta.env.DEV && (
      <script is:inline>
        (() => {
          // Respect Do Not Track and avoid work on constrained connections.
          const dnt = navigator.doNotTrack === '1' || window.doNotTrack === '1';
          const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
          const saveData = !!conn?.saveData;
          if (dnt || saveData) return;

          const loadScript = (src) => new Promise((resolve, reject) => {
            const s = document.createElement('script');
            s.src = src;
            s.async = true;
            s.onload = resolve;
            s.onerror = reject;
            document.head.appendChild(s);
          });

          const bootAnalytics = async () => {
            try {
              await loadScript('https://www.googletagmanager.com/gtag/js?id=G-M2Q4Q201KD');
              window.dataLayer = window.dataLayer || [];
              function gtag(){ window.dataLayer.push(arguments); }
              gtag('js', new Date());
              gtag('config', 'G-M2Q4Q201KD');
            } catch {}

            try {
              await loadScript('https://us-assets.i.posthog.com/static/array.js');
              window.posthog = window.posthog || [];
              if (window.posthog.init) {
                window.posthog.init('phc_EU6P0JMVeyYvnjVsCwHOFHqIc0muXCDdXBhG6yqe4Br', {
                  api_host: 'https://us.i.posthog.com',
                  person_profiles: 'identified_only'
                });
              }
            } catch {}
          };

          const idle = window.requestIdleCallback
            ? (fn) => window.requestIdleCallback(fn, { timeout: 2500 })
            : (fn) => setTimeout(fn, 1200);

          let started = false;
          const startOnce = () => {
            if (started) return;
            started = true;
            idle(bootAnalytics);
          };

          // Prefer first interaction so analytics never competes with initial render.
          const interactionEvents = ['pointerdown', 'keydown', 'touchstart', 'scroll'];
          const onInteraction = () => {
            startOnce();
          };
          interactionEvents.forEach((eventName) => {
            window.addEventListener(eventName, onInteraction, { once: true, passive: true });
          });

          // No timer fallback: keep analytics fully off the critical path.
          // It boots on first real interaction only.
        })();
      </script>
    )}
  </body>
</html>
